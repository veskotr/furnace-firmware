menu "Coordinator"


    config COORDINATOR_TASK_STACK_SIZE
        int "Coordinator Task Stack Size"
        default 4096

    config COORDINATOR_TASK_PRIORITY
        int "Coordinator Task Priority"
        default 5

    config COORDINATOR_TASK_NAME
        string "Coordinator Task Name"
        default "COORDINATOR_TASK"

    config COORDINATOR_MAX_HEATING_PROFILE_STEPS
        int "Max heating profile steps"
        default 20

    config COORDINATOR_MAX_PROFILES_STORED
        int "Max number of stored profiles"
        default 5

    config COORDINATOR_PID_TICK_INTERVAL_MS
        int "PID control loop tick interval (ms)"
        default 1000
        range 100 10000
        help
            How often the PID control loop runs (computes target temp,
            runs PID, and sends power to the heater). 1000 ms = 1 Hz.

    config COORDINATOR_PROFILE_COMPLETE_TEMP_C
        int "Temperature threshold for profile completion (C)"
        default 40
        range 20 100
        help
            The profile is considered complete when the cooldown stage
            has been reached AND the measured temperature drops below
            this value.

    config COORDINATOR_OVERSHOOT_THRESHOLD_C
        int "Maximum allowed overshoot above setpoint (C)"
        default 30
        range 5 100
        help
            If the measured temperature exceeds the current setpoint by
            more than this value, the program is emergency-stopped and
            the heater is cut. Protects against runaway temperatures.

    config COORDINATOR_STALL_CHECK_MS
        int "Heating stall detection window (ms)"
        default 180000
        range 60000 600000
        help
            During HEATING, if the measured temperature has not risen by
            at least the expected amount (based on the setpoint ramp) within
            this time window, the program is paused and a stall error is
            reported.  Default is 180000 ms (3 minutes).

    config COORDINATOR_COMPONENT_ID
        int "Coordinator Component ID"
        default 4
        help
            Unique identifier for the Coordinator component used by the health monitor.

    config COORDINATOR_HEARTBEAT_TIMEOUT_MS
        int "Coordinator Heartbeat Timeout (ms)"
        default 5000
        help
            Maximum time between heartbeats before the health monitor considers the coordinator unhealthy.

endmenu