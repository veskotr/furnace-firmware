menu "MODBUS Temperature Monitor (MS9024)"

    config MODBUS_TEMP_ENABLED
        bool "Enable MODBUS RTU temperature sensor (MS9024)"
        default n
        help
            Enable reading temperature from an MS9024 MODBUS RTU transmitter
            connected via RS485. When enabled, this replaces the SPI-based
            MAX31865 temperature monitor.

    if MODBUS_TEMP_ENABLED

    config MODBUS_TEMP_RS485_TX_PIN
        int "RS485 TX GPIO pin"
        default 27

    config MODBUS_TEMP_RS485_RX_PIN
        int "RS485 RX GPIO pin"
        default 26

    config MODBUS_TEMP_RS485_DE_PIN
        int "RS485 DE (direction enable) GPIO pin"
        default 25
        help
            Direction-enable pin for the RS485 transceiver.
            NOTE: Default 25 conflicts with CONFIG_HEATER_CONTROLLER_GPIO.
            If using MODBUS, change heater GPIO to 22 in Heater Controller menu.

    config MODBUS_TEMP_UART_PORT
        int "UART port number (0-2)"
        default 2
        range 0 2
        help
            UART0 = console, UART1 = Nextion HMI, UART2 = free for RS485.

    config MODBUS_TEMP_SLAVE_ADDR
        int "MS9024 MODBUS slave address"
        default 1
        range 1 247

    config MODBUS_TEMP_BAUD_RATE
        int "MODBUS baud rate"
        default 9600

    config MODBUS_TEMP_PV_REGISTER
        int "PV (temperature) register address"
        default 728
        help
            MS9024 register that holds the measured process value (temperature).
            728 = IEEE754 float at RAM register 216 + 512.
            Uses MODBUS function code 03 (read holding registers), 2 registers.

    config MODBUS_TEMP_SENSOR_TYPE
        int "Desired MS9024 sensor type (SENS register)"
        default 16
        range 0 24
        help
            The sensor type code to configure on the MS9024 at startup.
            If the MS9024's SENS register differs, firmware will auto-correct it.
            Common values for Pt100:
              16 = Pt100 a=0.003851 (EN 60751 / IEC 751)
              20 = Pt100 a=0.003920 (JIS C 1604)
              21 = Pt100 a=0.003910 (ITS-90 / Callendar-Van Dusen)
            Other RTD types:
              14 = Pt10 385,  15 = Pt50 385,  17 = Pt200 385
              18 = Pt500 385, 19 = Pt1000 385

    config MODBUS_TEMP_WIRE_MODE
        int "RTD wiring mode (2, 3, or 4-wire)"
        default 4
        range 2 4
        help
            The wiring mode for the RTD probe connected to the MS9024.
            If different from the MS9024's current setting, firmware will
            auto-correct it at startup.
              2 = 2-wire (terminals 1 and 4 only)
              3 = 3-wire (terminals 1, 2, and 4)
              4 = 4-wire (terminals 1, 2, 3, and 4)
            TIP: Try 2-wire mode if 4-wire gives wrong readings — useful
            for diagnosing 4-wire measurement circuit issues.

    config MODBUS_TEMP_READ_INTERVAL_MS
        int "Temperature read interval (ms)"
        default 1000
        range 200 10000

    config MODBUS_TEMP_RESPONSE_TIMEOUT_MS
        int "MODBUS response timeout (ms)"
        default 500
        range 100 5000
        help
            How long to wait for a response from the MS9024 after sending
            a MODBUS request. Increase if you see timeout errors.

    config MODBUS_TEMP_MAX_CONSECUTIVE_ERRORS
        int "Max consecutive read errors before alarm"
        default 10
        range 3 100

    endif # MODBUS_TEMP_ENABLED

endmenu
