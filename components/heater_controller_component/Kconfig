menu "Heater Controller"
    config HEATER_CONTROLLER_GPIO
        int "GPIO Pin"
        default 25

    config HEATER_WINDOW_SIZE_MS
        int "Heater Window Size (ms)"
        default 10000

    config HEATER_CONTROLLER_TASK_NAME
        string "Heater Controller Task Name"
        default "heater_controller_task"

    config HEATER_CONTROLLER_TASK_STACK_SIZE
        int "Heater Controller Task Stack Size"
        default 4096

    config HEATER_CONTROLLER_TASK_PRIORITY
        int "Heater Controller Task Priority"
        default 5

    config HEATER_CONTROLLER_COMPONENT_ID
        int "Heater Controller Component ID"
        default 2
        help
            Unique identifier for the Heater Controller component used by the health monitor.

    config HEATER_CONTROLLER_HEARTBEAT_TIMEOUT_MS
        int "Heater Controller Heartbeat Timeout (ms)"
        default 15000
        help
            Maximum time between heartbeats before the health monitor considers the heater controller unhealthy.
            Should be larger than HEATER_WINDOW_SIZE_MS.

endmenu